# .bash_aliases managed by ansible

alias ll="ls -l"
alias fix-pinentry='gpg-connect-agent updatestartuptty /bye > /dev/null 2>&1'
alias mount-encrypted='veracrypt --mount /dev/sda1 /mnt --slot 1'
alias unmount-encrypted='veracrypt --dismount --slot 1'
alias whatsmyip='curl ifconfig.me/ip'

# There's already a .bashrc that comes from /etc/skel so we have to place things
# that would usually go in there in this file, which is sourced from .bashrc.

if [ -d $HOME/.rbenv ]; then
  export PATH="$HOME/.rbenv/bin:$PATH"
  eval "$(rbenv init -)"
fi

# https://gist.github.com/trey/2722934
source /etc/profile.d/bash_completion.sh
GIT_PS1_SHOWDIRTYSTATE=true
GIT_PS1_SHOWCOLORHINTS=true

PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]$(__git_ps1)]\$ '

# Configure gpg-agent.
GPG_TTY=$(tty)
export GPG_TTY
export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
gpgconf --launch gpg-agent
# Make sure pinentry knows what terminal to display on.
gpg-connect-agent updatestartuptty /bye > /dev/null 2>&1
